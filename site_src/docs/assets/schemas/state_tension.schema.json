{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "state_tension.schema.json",
  "title": "State Civilizational Tension Tensor",
  "description": "T(s) in R^{6x6}, symmetric positive semi-definite, analogous to the continuum mechanics stress tensor.",
  "type": "object",
  "required": ["iso3", "T", "eigenvalues", "eigenvectors", "invariants", "anisotropy"],
  "properties": {
    "iso3": { "type": "string", "minLength": 3, "maxLength": 3 },
    "T": {
      "type": "array",
      "minItems": 6,
      "maxItems": 6,
      "items": {
        "type": "array",
        "minItems": 6,
        "maxItems": 6,
        "items": { "type": "number" }
      }
    },
    "eigenvalues": {
      "type": "array",
      "description": "Sorted descending: lambda_1 >= ... >= lambda_6.",
      "minItems": 6,
      "maxItems": 6,
      "items": { "type": "number" }
    },
    "eigenvectors": {
      "type": "array",
      "description": "Orthonormal basis: column k is e_k associated with lambda_k.",
      "minItems": 6,
      "maxItems": 6,
      "items": {
        "type": "array",
        "minItems": 6,
        "maxItems": 6,
        "items": { "type": "number" }
      }
    },
    "invariants": {
      "type": "object",
      "required": ["I1", "I2", "det"],
      "properties": {
        "I1": { "type": "number", "description": "trace(T) - total tension" },
        "I2": { "type": "number", "description": "von-Mises analogue" },
        "det": { "type": "number", "description": "determinant - civilizational rigidity" }
      }
    },
    "anisotropy": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "A = (lambda_1 - lambda_6) / lambda_1, or 0 when lambda_1 ~ 0."
    },
    "quality_flags": {
      "type": "object",
      "properties": {
        "monocivilizational": { "type": "boolean" },
        "low_evidence": { "type": "boolean" },
        "computed_from_imputed": { "type": "boolean" }
      }
    }
  },
  "additionalProperties": false
}
